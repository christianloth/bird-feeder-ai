# Grafana admin (the login inside Grafana itself — normally bypassed by anonymous viewer mode)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=prettybirds

# Public root URL. For ngrok, set this to your ngrok URL + /grafana/
# Example: https://your-name.ngrok-free.app/grafana/
GF_ROOT_URL=http://localhost/grafana/

# Caddy basic auth — the single gate in front of everything (API + Grafana).
# Generate the bcrypt hash once:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'prettybirds'
# Paste the resulting $2a$... string below, escaping every literal $ as $$ for docker-compose.
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=

# Where Caddy finds the FastAPI backend on the host
API_UPSTREAM=host.docker.internal:8000
