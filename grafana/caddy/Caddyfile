{
	admin off
	auto_https disable_redirects
	local_certs
	default_sni 192.168.1.211
}

(site) {
	# Public, UNGATED Grafana surface: ONLY the published public-dashboard page,
	# its public data API, and the shared static JS/CSS bundle. This is the sole
	# anonymous Grafana path — no login, no admin UI, no /api/ds/query, and no
	# data writes (the SQLite datasource opens read-only). Listed BEFORE @grafana
	# so these paths skip the basic_auth gate below. Viewers cannot modify the
	# dashboard (public dashboards are read-only by design).
	@grafana_public path /grafana/public-dashboards/* /grafana/api/public/* /grafana/public/*
	handle @grafana_public {
		reverse_proxy grafana:3000
	}

	# SECURITY: everything else under /grafana — the admin UI, the login page, and
	# the arbitrary-SQL query API (/api/ds/query) — stays gated behind HTTP basic
	# auth (CADDY_BASIC_AUTH_*; the password is the FastAPI admin token). Nested
	# `route` so basic_auth runs FIRST, before the redirect/proxy. The FastAPI
	# dashboard ("handle {}" below) stays public on purpose.
	@grafana path /grafana /grafana/ /grafana/*
	handle @grafana {
		route {
			basic_auth {
				{$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
			}
			redir /grafana /grafana/d/bird-feeder-main/bird-feeder 302
			redir /grafana/ /grafana/d/bird-feeder-main/bird-feeder 302
			reverse_proxy grafana:3000
		}
	}

	@root path /
	redir @root /dashboard 302

	handle {
		reverse_proxy {$API_UPSTREAM}
	}
}

:80 {
	import site
}

https://192.168.1.211, https://localhost, https://127.0.0.1 {
	tls internal
	import site
}
