# Bird Feeder AI Configuration
# This file is gitignored -- do not commit (contains camera credentials).

# --- Logging ---
log_level: INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Camera ---
camera:
  rtsp_url: "rtsp://admin:password@192.168.1.100:554/11"
  # "h264" = software decode via FFMPEG (OpenCV CAP_FFMPEG).
  # "h265" = software decode via GStreamer (avdec_h265). Camera must output H.265.
  # NOTE: VideoCore VII HW H.265 decode (v4l2slh265dec) is currently broken on
  # this stack (Debian Trixie + Mesa 25.0.7 + GStreamer 1.26.2) — the GL detile
  # path silently produces all-black frames in headless sessions. See memory
  # project_h265_hw_decode_failed.md for retry conditions.
  codec: "h264"
  # Rotate incoming RTSP frames. Positive = counterclockwise, negative = clockwise.
  # Use 0 to disable. For 90/180/270, a fast lossless rotation is used; other
  # angles use an affine warp (slightly slower, may add black borders).
  rotation_degrees: 0

# --- Daytime: Bird Detection (Stage 1) ---
# YOLO model that scans each frame for birds (COCO class 14).
# This only answers "is there a bird?" and draws a bounding box. REQUIRED.
bird_detection:
  model: "models/base-models/yolo11n.pt"
  hef_model: "yolov11s.hef"   # HEF model filename in models/hef/ for Hailo NPU
  confidence_threshold: 0.4   # min confidence to consider a YOLO detection a bird
  bird_class_id: 14            # COCO class 14 = "bird"
  # Pixel regions to ignore. Any detection whose bbox overlaps an ignore
  # region by more than ignore_overlap_threshold (fraction of the detection's
  # area) is dropped before classification. Useful for suppressing static
  # fake birds / decoys at fixed pixel locations.
  # Coordinates are [x1, y1, x2, y2] in the rotated frame.
  ignore_regions: []
  # Example:
  # ignore_regions:
  #   - [624, 0, 744, 100]
  ignore_overlap_threshold: 0.5

# --- Daytime: Species Classification (Stage 2) ---
# ViT-Small classifier that takes the cropped bird from Stage 1
# and predicts which of 555 NABirds species it is.
# ViT-Small chosen for fine-grained classification — self-attention captures
# long-range relationships between discriminative bird features (bill ↔ tail).
species_classification:
  hef_model: "vit_small_birds.hef"  # HEF model filename in models/hef/
  confidence_threshold: 0.60  # min confidence to accept a species prediction
  # Species to suppress entirely. IDs are from data/nabirds/classes.txt
  # (first column — e.g. 338 = "California Quail (Male)"). If the classifier's
  # top prediction (after logit averaging) lands on one of these, the
  # detection is dropped — no database save, no alert. Useful for silencing
  # persistent false positives.
  disabled_species_ids: []
  # Example:
  # disabled_species_ids:
  #   - 338   # California Quail (Male)

# --- Nighttime: Wildlife Detection (single-stage) ---
# Custom YOLO that detects AND classifies 11 wildlife classes in one shot.
# No separate classifier — the species comes directly from this model. REQUIRED.
wildlife_detection:
  model: "models/wildlife/yolo11s-wildlife-equal/weights/best.pt"
  confidence_threshold: 0.4   # min confidence to accept a wildlife detection

# --- Day/Night Mode ---
day_night:
  mode_check_interval: 60    # Seconds between sun time checks
  night_offset_minutes: 30   # Start night mode this many minutes after sunset
  day_offset_minutes: 30     # Start day mode this many minutes before sunrise

# --- Pipeline ---
pipeline:
  process_every_n: 5             # Process every Nth frame (higher = less CPU)
  species_cooldown_seconds: 120  # Suppress duplicate DB saves of same species for N seconds
  min_frames_for_detection: 3   # Consecutive frames a bird must appear before being sent downstream (1 = immediate)

# --- Location (for sunrise/sunset calculation) ---
location:
  latitude: 33.1507    # Frisco, TX
  longitude: -96.8236
  timezone: "America/Chicago"

# --- Features ---
# Toggle individual UI tabs / experimental features without rebuilding.
features:
  sweep: true   # /sweep page — bulk-delete detections inside ignore regions

# --- Storage ---
storage:
  save_crops: true
  crop_quality: 85
  thumbnail_size: [200, 200]
  thumbnail_quality: 75
  retention_days: 90  # Delete detection images older than this
