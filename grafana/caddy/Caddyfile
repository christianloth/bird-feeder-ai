{
	admin off
	auto_https disable_redirects
	local_certs
	default_sni 192.168.1.211
}

(site) {
	# Grafana is PUBLIC, read-only by design: anonymous visitors get the Viewer
	# role (GF_AUTH_ANONYMOUS_*), the sqlite datasource opens birds.db in
	# read-only mode (verified: writes via /api/ds/query fail SQLITE_READONLY),
	# and admin/editor access still requires the Grafana login (strong rotated
	# password in grafana/.env). Cloudflare rate-limits /grafana* at the edge.
	# `handle` (so the catch-all handle below doesn't also match /grafana) with a
	# nested `route` so directive order is honored.
	@grafana path /grafana /grafana/ /grafana/*
	handle @grafana {
		route {
			redir /grafana /grafana/d/bird-feeder-main/bird-feeder 302
			redir /grafana/ /grafana/d/bird-feeder-main/bird-feeder 302
			reverse_proxy grafana:3000
		}
	}

	@root path /
	redir @root /dashboard 302

	handle {
		reverse_proxy {$API_UPSTREAM}
	}
}

:80 {
	import site
}

https://192.168.1.211, https://localhost, https://127.0.0.1 {
	tls internal
	import site
}
