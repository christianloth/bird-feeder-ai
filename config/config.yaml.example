# Bird Feeder AI Configuration
# This file is gitignored -- do not commit (contains camera credentials).

# --- Logging ---
log_level: INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Camera ---
camera:
  rtsp_url: "rtsp://admin:password@192.168.1.100:554/11"

# --- Daytime: Bird Detection (Stage 1) ---
# YOLO model that scans each frame for birds (COCO class 14).
# This only answers "is there a bird?" and draws a bounding box. REQUIRED.
bird_detection:
  model: "models/base-models/yolo11n.pt"
  confidence_threshold: 0.4   # min confidence to consider a YOLO detection a bird
  bird_class_id: 14            # COCO class 14 = "bird"

# --- Daytime: Species Classification (Stage 2) ---
# EfficientNet-B2 classifier that takes the cropped bird from Stage 1
# and predicts which of 555 NABirds species it is.
species_classification:
  confidence_threshold: 0.60  # min confidence to accept a species prediction

# --- Nighttime: Wildlife Detection (single-stage) ---
# Custom YOLO that detects AND classifies 11 wildlife classes in one shot.
# No separate classifier — the species comes directly from this model. REQUIRED.
wildlife_detection:
  model: "models/wildlife/yolo11s-wildlife-equal/weights/best.pt"
  confidence_threshold: 0.4   # min confidence to accept a wildlife detection

# --- Day/Night Mode ---
day_night:
  mode_check_interval: 60    # Seconds between sun time checks
  night_offset_minutes: 30   # Start night mode this many minutes after sunset
  day_offset_minutes: 30     # Start day mode this many minutes before sunrise

# --- Pipeline ---
pipeline:
  process_every_n: 5  # Process every Nth frame (higher = less CPU)

# --- Location (for sunrise/sunset calculation) ---
location:
  latitude: 33.1507    # Frisco, TX
  longitude: -96.8236
  timezone: "America/Chicago"

# --- Storage ---
storage:
  save_crops: true
  crop_quality: 85
  thumbnail_size: [200, 200]
  thumbnail_quality: 75
  retention_days: 90  # Delete detection images older than this
